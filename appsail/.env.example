# ZCat Icons — Environment Variables
# Copy to .env and fill in your values

# AI Providers (at least one required for AI rewrite feature)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# CORS — comma-separated origins allowed in production
# Example: https://zcat-icons-20508000000125077.development.catalystserverless.com
ALLOWED_ORIGINS=

# Catalyst sets this automatically in production — do NOT set locally
# X_ZOHO_CATALYST_LISTEN_PORT=3000
